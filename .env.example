NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Luma calendar API key.
# Docs: https://docs.luma.com/reference/get_v1-calendar-list-events
# Note: Luma lists events managed by the calendar attached to this key.
LUMA_API_KEY=

# Eventfinda API credentials.
# Docs: https://www.eventfinda.sg/api/v2/events
EVENTFINDA_USERNAME=
EVENTFINDA_PASSWORD=

# Optional. Leave empty to fetch all Singapore-area Eventfinda events.
# Defaults to youth/student/community-oriented terms.
EVENTFINDA_QUERY=

# Nightly scraper schedule. 0 23 * * * means every day at 23:00.
SCRAPER_CRON=0 23 * * *
SCRAPER_TIMEZONE=Asia/Singapore

# Optional but recommended for Vercel Cron. If set in Vercel project env,
# Vercel sends Authorization: Bearer <CRON_SECRET> to cron endpoints.
CRON_SECRET=
